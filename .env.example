# Backend Configuration

# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://user:password@localhost:3306/dairy_management

# JWT Secrets (min 16 characters each)
JWT_ACCESS_SECRET=your-access-secret-key-min-16-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-16-chars

# JWT Expiration
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-session-secret-key-min-8-chars

# Security
BCRYPT_SALT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# CORS
CORS_ORIGIN=http://localhost:3000
